# 楽天ウェブサービス（楽天市場商品検索API + 楽天アフィリエイト）
RAKUTEN_APP_ID=your_rakuten_application_id
RAKUTEN_AFFILIATE_ID=your_rakuten_affiliate_id

# X (Twitter) API - 投稿権限(Read and Write)を持つアプリのキー / OAuth1.0aユーザーコンテキスト
X_API_KEY=your_x_api_key
X_API_KEY_SECRET=your_x_api_key_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# true にすると実際には投稿せず、コンソールに投稿予定内容を出力するだけになります
DRY_RUN=false
